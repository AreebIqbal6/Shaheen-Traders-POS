{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Shaheen Global Traders POS",
  "version": "0.1.16",
  "identifier": "com.shaheen.pos.global",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Shaheen Traders POS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AreebIqbal6/Shaheen-Traders-POS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCRkNDQkREQ0U4MDhGN0MKUldSOGo0RE8zY3Y4RzFVT2lzK3N1UUdNR1IveEV3TlNVM1AxSEZpK3VUd3BUNlVpWldVQTRFcUQK"
    },
    "cli": {
      "description": "Shaheen Traders POS CLI",
      "longDescription": "Launch Shaheen POS in Admin or Booker mode directly.",
      "args": [
        {
          "name": "mode",
          "short": "m",
          "description": "The mode to run the POS in (admin or booker)",
          "takesValue": true
        }
      ]
    }
  }
}
