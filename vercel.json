{
  "headers": [
    {
      "source": "/(sw\\.js|index\\.html|manifest\\.webmanifest|workbox-.*\\.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
